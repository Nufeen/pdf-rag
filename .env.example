OLLAMA_BASE_URL=http://192.168.1.X:11434  # Ollama server URL

# Embedding model for indexing and retrieval
EMBED_MODEL=mxbai-embed-large         

# LLM models (three-tier system — all default to DEEP_MODEL if unset)
DEEP_MODEL=command-r:35b              # Quality model: used for ask and final research synthesis
FAST_MODEL=mistral:7b                 # Medium model: per-sub-question answers and intermediate synthesis
TINY_MODEL=qwen2.5:3b                 # Fast model: planning sub-questions and reflection

# Multilingual search (pedro research only)
SEARCH_LANGUAGES=Russian              # Comma-separated languages to translate sub-questions into
TRANSLATE_MODEL=qwen2.5:3b            # Model for translation (defaults to TINY_MODEL)

# ChromaDB storage path
DB_PATH=~/.pdf-rag/chroma_db          

# Parameters
CHUNK_SIZE=800                        # Characters per chunk
TOP_K=5                               # Chunks retrieved per query

# Characters shared between consecutive chunks 
# to preserve context across boundaries
CHUNK_OVERLAP=150                     

RESEARCH_DEPTH=2                          # Max reflection iterations for pedro research
RESEARCH_N_SUBQUESTIONS=3                 # Sub-questions per iteration for pedro research
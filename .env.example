OLLAMA_BASE_URL=http://192.168.1.X:11434  # Ollama server URL

# Embedding model for indexing and retrieval
RAG_EMBED_MODEL=mxbai-embed-large         

# LLM models (three-tier system — all default to RAG_DEEP_MODEL if unset)
RAG_DEEP_MODEL=command-r:35b              # Quality model: used for ask and final research synthesis
RAG_FAST_MODEL=mistral:7b                 # Medium model: per-sub-question answers and intermediate synthesis
RAG_TINY_MODEL=qwen2.5:3b                 # Fast model: planning sub-questions and reflection

# Multilingual search (pedro research only)
RAG_SEARCH_LANGUAGES=Russian              # Comma-separated languages to translate sub-questions into
RAG_TRANSLATE_MODEL=qwen2.5:3b            # Model for translation (defaults to RAG_TINY_MODEL)

# ChromaDB storage path
RAG_DB_PATH=~/.pdf-rag/chroma_db          

# Parameters
RAG_CHUNK_SIZE=800                        # Characters per chunk
RAG_TOP_K=5                               # Chunks retrieved per query

# Characters shared between consecutive chunks 
# to preserve context across boundaries
RAG_CHUNK_OVERLAP=150                     

RESEARCH_DEPTH=2                          # Max reflection iterations for pedro research
RESEARCH_N_SUBQUESTIONS=3                 # Sub-questions per iteration for pedro research